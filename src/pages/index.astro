---
import Layout from '../layouts/Layout.astro';

// 1. DATA DE VIDEOS
const projects = [
  { title: 'The Silent Frame', category: 'Short Film', vimeoId: '76979871', image: 'https://images.unsplash.com/photo-1485846234645-a62644f84728?q=80&w=1200' },
  { title: 'Urban Echoes', category: 'Music Video', vimeoId: '76979871', image: 'https://images.unsplash.com/photo-1478720568477-152d9b164e26?q=80&w=1200' },
  { title: 'Midnight Motion', category: 'Commercial', vimeoId: '76979871', image: 'https://images.unsplash.com/photo-1536244636800-a3f74db0f3cf?q=80&w=1200' },
  { title: 'Aperture Series', category: 'Documentary', vimeoId: '76979871', image: 'https://images.unsplash.com/photo-1550684848-fac1c5b4e853?q=80&w=1200' },
  { title: 'Deep Focus', category: 'Experimental', vimeoId: '76979871', image: 'https://images.unsplash.com/photo-1485846234645-a62644f84728?q=80&w=1200' },
  { title: 'Grain & Light', category: 'Studio', vimeoId: '76979871', image: 'https://images.unsplash.com/photo-1523206489230-c012c64b2b48?q=80&w=1200' },
];

// 2. DATA DE FOTOS (STILLS)
const stillProjects = [
  { title: 'Aperture Series', category: 'Portrait', image: 'https://images.unsplash.com/photo-1550684848-fac1c5b4e853?q=80&w=1200' },
  { title: 'Deep Focus', category: 'Landscape', image: 'https://images.unsplash.com/photo-1485846234645-a62644f84728?q=80&w=1200' },
  { title: 'Grain & Light', category: 'Experimental', image: 'https://images.unsplash.com/photo-1523206489230-c012c64b2b48?q=80&w=1200' },
  { title: 'Shadow Play', category: 'Studio', image: 'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?q=80&w=1200' },
];

const mainProjects = projects.slice(0, 3);
const gridProjects = projects.slice(3);
---

<Layout>
  <section class="pt-40 px-8 md:px-20 pb-20 mx-auto">
    <span class="text-[10px] font-mono uppercase tracking-[0.4em] opacity-40 mb-12 block">[02] Videos</span>
    
    <div class="flex flex-col gap-y-12 mb-12">
      {mainProjects.map((project) => (
        <div class="project-item video-item group cursor-pointer relative overflow-hidden" data-vimeo-id={project.vimeoId}>
  
          <div class="bg-zinc-900 aspect-video md:max-h-[80vh]">
            <img 
              src={project.image} 
              alt={project.title} 
              class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000 ease-in-out scale-105 group-hover:scale-100" 
            />
          </div>

          <div class="absolute inset-0 flex flex-col justify-center items-center p-6
                      bg-black/0 group-hover:bg-black/60 
                      transition-all duration-700 ease-in-out">
            
            <h2 class="text-white text-3xl md:text-5xl tracking-tighter
                      opacity-0 group-hover:opacity-100 
                      translate-y-4 group-hover:translate-y-0 
                      transition-all duration-700 delay-100 text-center">
              {project.title}
            </h2>

            <span class="text-white/90 text-[14px] font-mono tracking-[0.3em] uppercase mt-4
                        opacity-0 group-hover:opacity-100 
                        transition-all duration-700 delay-200">
              [{project.category}]
            </span>
            
          </div>
        </div>
      ))}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
  
      {/* PROYECTO GRANDE (Izquierda - Aspect 3/4) */}
      {gridProjects[0] && (
        <div class="project-item video-item group cursor-pointer relative overflow-hidden flex flex-col" data-vimeo-id={gridProjects[0].vimeoId}>
          <div class="bg-zinc-900 aspect-[3/4]"> 
            <img src={gridProjects[0].image} alt={gridProjects[0].title} class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000 ease-in-out scale-105 group-hover:scale-100" />
          </div>

          <div class="absolute inset-0 flex flex-col justify-center items-center p-6 bg-black/0 group-hover:bg-black/60 transition-all duration-700 ease-in-out">
            <h2 class="text-white text-2xl md:text-4xl tracking-tighter opacity-0 group-hover:opacity-100 translate-y-4 group-hover:translate-y-0 transition-all duration-700 delay-100 text-center">
              {gridProjects[0].title}
            </h2>
            <span class="text-white/60 text-[9px] font-mono tracking-[0.3em] uppercase mt-4 opacity-0 group-hover:opacity-100 transition-all duration-700 delay-200">
              [{gridProjects[0].category}]
            </span>
          </div>
        </div>
      )}

      {/* COLUMNA DERECHA (Dos proyectos alineados arriba y abajo) */}
      <div class="flex flex-col justify-between md:gap-6">
        {gridProjects.slice(1, 3).map((project, index) => (
          <div 
            class={`project-item group video-item cursor-pointer relative overflow-hidden h-full ${index === 0 ? 'mb-0' : ''}`} 
            data-vimeo-id={project.vimeoId}
          >
            <div class="bg-zinc-900 h-full aspect-video">
              <img src={project.image} alt={project.title} class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000 ease-in-out scale-105 group-hover:scale-100" />
            </div>

            <div class="absolute inset-0 flex flex-col justify-center items-center p-6 bg-black/0 group-hover:bg-black/60 transition-all duration-700 ease-in-out">
              <h2 class="text-white text-xl md:text-2xl tracking-tighter opacity-0 group-hover:opacity-100 translate-y-4 group-hover:translate-y-0 transition-all duration-700 delay-100 text-center">
                {project.title}
              </h2>
              <span class="text-white/60 text-[8px] font-mono tracking-[0.3em] uppercase mt-2 opacity-0 group-hover:opacity-100 transition-all duration-700 delay-200">
                [{project.category}]
              </span>
            </div>
          </div>
        ))}
      </div>
    </div>


    
  </section>

  <section class="px-8 md:px-20 py-20 mx-auto border-t">
    <span class="text-[10px] font-mono uppercase tracking-[0.4em] opacity-40 mb-12 block">[02] Fotografías</span>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-8">
      {stillProjects.map((still) => (
        <div class="still-item group cursor-pointer relative overflow-hidden" data-full-img={still.image}>
          <div class="bg-zinc-900 aspect-video overflow-hidden">
            <img src={still.image} alt={still.title} class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000 ease-in-out scale-105 group-hover:scale-100" />
          </div>
          <div class="absolute inset-0 flex flex-col justify-center items-center p-6 bg-black/0 group-hover:bg-black/60 transition-all duration-700 ease-in-out">
            <h2 class="text-white text-3xl font-light  opacity-0 group-hover:opacity-100 translate-y-4 group-hover:translate-y-0 transition-all duration-700 text-center">
              {still.title}
            </h2>
            <p class="text-white/60 text-[10px] uppercase font-mono tracking-[0.2em] mt-2 opacity-0 group-hover:opacity-100 transition-all duration-700">Ver fotografía</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <div id="global-modal" class="fixed inset-0 z-[100] flex items-center justify-center bg-black/95 opacity-0 pointer-events-none transition-all duration-500 backdrop-blur-sm p-4 md:p-10">
    <button id="close-modal" class="absolute top-10 right-10 text-white text-[10px] tracking-[0.3em] uppercase z-[110] hover:text-blue-500 transition-colors cursor-pointer">
      Cerrar / Esc
    </button>
    
    <div id="video-container" class="hidden w-full max-w-7xl aspect-video">
      <iframe id="vimeo-player" src="" class="w-full h-full" frameborder="0" allow="autoplay; fullscreen" allowfullscreen></iframe>
    </div>

    <div id="image-container" class="hidden w-full h-full flex items-center justify-center">
      <img id="modal-img" src="" class="max-w-full max-h-full object-contain scale-95 transition-transform duration-500" />
    </div>
  </div>
</Layout>

<script>
  const modal = document.getElementById('global-modal');
  const videoContainer = document.getElementById('video-container');
  const imageContainer = document.getElementById('image-container');
  const iframe = document.getElementById('vimeo-player') as HTMLIFrameElement;
  const modalImg = document.getElementById('modal-img') as HTMLImageElement;
  const closeBtn = document.getElementById('close-modal');

  // Lógica para VIDEOS
  document.querySelectorAll('.video-item').forEach(item => {
    item.addEventListener('click', () => {
      const vimeoId = item.getAttribute('data-vimeo-id');
      if (vimeoId) {
        iframe.src = `https://player.vimeo.com/video/${vimeoId}?autoplay=1&color=ffffff&title=0&byline=0`;
        videoContainer?.classList.remove('hidden');
        imageContainer?.classList.add('hidden');
        openModal();
      }
    });
  });

  // Lógica para FOTOS (STILLS)
  document.querySelectorAll('.still-item').forEach(item => {
    item.addEventListener('click', () => {
      const imgUrl = item.getAttribute('data-full-img');
      if (imgUrl) {
        modalImg.src = imgUrl;
        imageContainer?.classList.remove('hidden');
        videoContainer?.classList.add('hidden');
        openModal();
        setTimeout(() => modalImg.classList.add('scale-100'), 10);
      }
    });
  });

  function openModal() {
    modal?.classList.remove('opacity-0', 'pointer-events-none');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal?.classList.add('opacity-0', 'pointer-events-none');
    iframe.src = "";
    modalImg.src = "";
    modalImg.classList.remove('scale-100');
    document.body.style.overflow = 'auto';
  }

  closeBtn?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
  window.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
</script>