
---
import '../styles/global.css'

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { 
  title = "Stills — Productora audiovisual", 
  description = "Productora boutique basada en la narrativa visual y la estética minimalista. Especializados en cine, comerciales y videoclips.",
  image = "/og-image.jpg" // Una imagen de 1200x630px que represente a la productora
} = Astro.props;

const canonicalURL = Astro.url;

const base = import.meta.env.BASE_URL;
const navLinks = [
  { name: 'Trabajos', href: `${base}/`.replace(/\/+/g, '/') },
  { name: 'Nosotros', href: `${base}/nosotros`.replace(/\/+/g, '/') },
  { name: 'Contacto', href: `${base}/contacto`.replace(/\/+/g, '/') },
];

---

<!doctype html>
<html lang="es">
	<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="title" content={title} /> 
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.url)} />

    <link rel="preconnect" href="https://fonts.googleapis.com"> 
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  </head>
	<body class="text-[#fcfcfc] bg-[#000000] antialiased selection:bg-black selection:text-white">
		
		<nav class="fixed top-0 w-full z-[100] bg-black/90 backdrop-blur-md px-6 md:px-20 py-6 md:py-8 flex justify-between items-center border-b border-white/5">
  
      <a href={base} class="z-[110] hover:opacity-80 transition-opacity">
        <img 
          width="120" 
          src={`${base}/logo-ss-full.png`.replace(/\/+/g, '/')} 
          alt="Logo San Productions"
          class="md:w-[150px] w-[100px]"
        />
      </a>

      <div class="hidden md:flex gap-8 items-center uppercase tracking-[0.3em] text-[10px] font-bold text-white">
        {navLinks.map(link => (
          <a href={link.href} class="hover:text-blue-500 transition-colors duration-300">
            {link.name}
          </a>
        ))}
      </div>

      <button id="menu-toggle" class="md:hidden z-[110] flex flex-col gap-1.5 p-2" aria-label="Abrir menú">
        <span class="w-6 h-[1px] bg-white transition-all duration-300" id="line1"></span>
        <span class="w-6 h-[1px] bg-white transition-all duration-300" id="line2"></span>
      </button>

      <div id="mobile-menu" class="fixed inset-0 bg-black h-screen translate-x-full transition-transform duration-500 ease-in-out flex flex-col justify-center items-center gap-8 md:hidden">
        {navLinks.map(link => (
          <a href={link.href} class="text-white uppercase tracking-[0.5em] text-lg  hover:text-gray-500 transition-colors">
            {link.name}
          </a>
        ))}
        
        <div class="absolute bottom-10 flex gap-4 opacity-30">
            <div class="w-1 h-1 rounded-full bg-gray-600"></div>
            <div class="w-1 h-1 rounded-full bg-gray-600"></div>
            <div class="w-1 h-1 rounded-full bg-gray-600"></div>
        </div>
      </div>

    </nav>

		<main>
			<slot />
		</main>

		<footer class="px-6 md:px-20 py-12 text-[10px] uppercase tracking-[0.3em] font-medium border-t border-zinc-100 mt-20">
      <div class="grid grid-cols-1 md:grid-cols-3 items-center gap-8 md:gap-0">
        
        <div class="flex items-center justify-center md:justify-start gap-2 text-zinc-400">
          
          <span>Disponible para proyectos 2026</span>
        </div>

        <div class="flex justify-center items-center gap-8">
          <a target="_blank" href="https://www.youtube.com/channel/UCB95SuS2QnCR6GpHkqWXlpA" target="_blank" class="hover:text-gray-600 transition-all duration-300 hover:-translate-y-1" aria-label="YouTube">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"/>
              <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/>
            </svg>
          </a>

          <a target="_blank" href="https://web.facebook.com/profile.php?id=61588372559071" target="_blank" class="hover:text-gray-600 transition-all duration-300 hover:-translate-y-1" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>

          <a target="_blank" href="https://www.instagram.com/stillsmedios?igsh=andoM3NzeHBraWZ6&utm_source=qr" target="_blank" class="hover:text-gray-600 transition-all duration-300 hover:-translate-y-1" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
            </svg>
          </a>
        </div>

        <div class="text-center md:text-right text-zinc-400">
          © {new Date().getFullYear()} — Stills
        </div>

      </div>
    </footer>

	</body>
</html>

<style is:global>
	body {
  /* Montserrat aplicada como fuente principal */
  font-family: "Montserrat", sans-serif;
}
</style>

<script>
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const line1 = document.getElementById('line1');
  const line2 = document.getElementById('line2');

  let isOpen = false;

  menuToggle?.addEventListener('click', () => {
    isOpen = !isOpen;
    
    if (isOpen) {
      mobileMenu?.classList.remove('translate-x-full');
      // Animación de la hamburguesa a X
      line1?.classList.add('rotate-45', 'translate-y-[3.5px]', 'bg-blue-500');
      line2?.classList.add('-rotate-45', '-translate-y-[3.5px]', 'bg-blue-500');
      document.body.style.overflow = 'hidden';
    } else {
      mobileMenu?.classList.add('translate-x-full');
      // Volver a hamburguesa
      line1?.classList.remove('rotate-45', 'translate-y-[3.5px]', 'bg-blue-500');
      line2?.classList.remove('-rotate-45', '-translate-y-[3.5px]', 'bg-blue-500');
      document.body.style.overflow = 'auto';
    }
  });

  // Cerrar menú al hacer click en un link
  const mobileLinks = mobileMenu?.querySelectorAll('a');
  mobileLinks?.forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('translate-x-full');
      line1?.classList.remove('rotate-45', 'translate-y-[4px]');
      line2?.classList.remove('-rotate-45', '-translate-y-[4px]');
      document.body.style.overflow = 'auto';
      isOpen = false;
    });
  });
</script>